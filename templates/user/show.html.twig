{% extends 'base.html.twig' %}

{% block title %}Utilisateur
{% endblock %}
{% block stylesheets %}
	<link rel="stylesheet" href="{{ asset('css/admin.css') }}">
{% endblock %}

{% block body %}
	<section>
		<a href="{{ path('app_user_index') }}" id="admin_menu_link">
			<i class="bi bi-caret-left-fill"></i>
			Retour aux utilisateurs</a>
		<h1>Utilisateur</h1>

		<table class="table">
			<tbody>
				<tr>
					<th>Pseudo</th>
					<td>{{ user.nickname }}</td>
				</tr>
				<tr>
					<th>Email</th>
					<td>{{ user.email }}</td>
				</tr>
				<tr>
					<th>Roles</th>
					<td>
						{# {{ user.roles ? user.roles|json_encode : '' }} #}
						{% for role in user.roles %}
							{{ role }}
						{% endfor %}
					</td>
				</tr>
				<tr>
					<th>Membre depuis</th>
					<td>{{ user.createdAt ? user.createdAt|date('d/m/Y') : '' }}</td>
				</tr>
			</tbody>
		</table>

		<a href="{{ path('app_user_edit', {'id': user.id}) }}" class="new-data-btn">Modifier</a>

		{{ include('user/_delete_form.html.twig') }}

	</section>
{% endblock %}
